    {"id":1,"question":"$2x(x+3)$을 전개하면?","choices":["$2x^2+6x$","$2x^2+3x$","$2x+6x$","$2x^2+6$","$x^2+6x$"],"answer":0,"explanation":"분배법칙: $2x\\times x+2x\\times 3=2x^2+6x$"},
    {"id":2,"question":"$3a(a-2b)$를 전개하면?","choices":["$3a^2-6ab$","$3a^2-2ab$","$3a^2-6b$","$3a-6ab$","$3a^2+6ab$"],"answer":0,"explanation":"$3a\\times a+3a\\times(-2b)=3a^2-6ab$"},
    {"id":3,"question":"$(8x^2-4x) \\div 2x$를 계산하면?","choices":["$4x-2$","$4x^2-2$","$4x-2x$","$8x-4$","$4x+2$"],"answer":0,"explanation":"각 항을 $2x$로 나눔: $8x^2\\div 2x=4x$, $4x\\div 2x=2$. 결과: $4x-2$"},
    {"id":4,"question":"$-3y(2y-1)$을 전개하면?","choices":["$-6y^2+3y$","$-6y^2-3y$","$6y^2+3y$","$-6y^2+1$","$-6y^2-1$"],"answer":0,"explanation":"$-3y\\times 2y+(-3y)\\times(-1)=-6y^2+3y$"},
    {"id":5,"question":"$(12a^2b-6ab) \\div 3ab$를 계산하면?","choices":["$4a-2$","$4a-2b$","$4ab-2$","$4a^2-2$","$4a+2$"],"answer":0,"explanation":"$12a^2b\\div 3ab=4a$, $6ab\\div 3ab=2$. 결과: $4a-2$"},
    {"id":6,"question":"$2x(x-1)-x^2$을 전개하면?","choices":["$x^2-2x$","$x^2+2x$","$3x^2-2x$","$x^2-x$","$2x^2-2x$"],"answer":0,"explanation":"$2x^2-2x-x^2=x^2-2x$"},
    {"id":7,"question":"$a(3a+2b)+2a(a-b)$를 전개하면?","choices":["$5a^2$","$5a^2+4ab$","$5a^2-4ab$","$5a^2+2ab$","$3a^2+2ab$"],"answer":0,"explanation":"$3a^2+2ab+2a^2-2ab=5a^2$"},
    {"id":8,"question":"$\\frac{9x^3-6x^2}{3x}$를 계산하면?","choices":["$3x^2-2x$","$3x^2-2$","$3x-2$","$9x^2-6x$","$3x^2+2x$"],"answer":0,"explanation":"$9x^3\\div 3x=3x^2$, $6x^2\\div 3x=2x$. 결과: $3x^2-2x$"},
    {"id":9,"question":"$-2x(3x-4)$를 전개하면?","choices":["$-6x^2+8x$","$-6x^2-8x$","$6x^2+8x$","$-6x^2+4$","$-6x-8x$"],"answer":0,"explanation":"$-2x\\times 3x+(-2x)\\times(-4)=-6x^2+8x$"},
    {"id":10,"question":"$(15x^2y^2-10xy^2) \\div 5xy$를 계산하면?","choices":["$3xy-2y$","$3x^2y-2y$","$3xy-2$","$3y-2xy$","$3xy+2y$"],"answer":0,"explanation":"$15x^2y^2\\div 5xy=3xy$, $10xy^2\\div 5xy=2y$. 결과: $3xy-2y$"},
    {"id":11,"question":"$3x(x+2y)-2x(x-y)$를 전개하면?","choices":["$x^2+8xy$","$x^2+6xy$","$x^2+4xy$","$5x^2+8xy$","$x^2-8xy$"],"answer":0,"explanation":"$3x^2+6xy-2x^2+2xy=x^2+8xy$"},
    {"id":12,"question":"$(4a^2b+2ab^2) \\div 2ab$를 계산하면?","choices":["$2a+b$","$2a-b$","$2a+2b$","$4a+2b$","$a+b$"],"answer":0,"explanation":"$4a^2b\\div 2ab=2a$, $2ab^2\\div 2ab=b$. 결과: $2a+b$"},
    {"id":13,"question":"$(x+2)(3x) = ?$","choices":["$3x^2+6x$","$3x^2+2x$","$3x+6$","$x^2+6x$","$3x^2-6x$"],"answer":0,"explanation":"$3x\\times x+3x\\times 2=3x^2+6x$"},
    {"id":14,"question":"$5a^2 - 3a(a-2)$를 계산하면?","choices":["$2a^2+6a$","$2a^2-6a$","$8a^2+6a$","$2a+6$","$8a^2-6a$"],"answer":0,"explanation":"$5a^2-3a^2+6a=2a^2+6a$"},
    {"id":15,"question":"$(18x^3-12x^2) \\div 6x^2$를 계산하면?","choices":["$3x-2$","$3x^2-2x$","$3x+2$","$18x-12$","$3x-2x$"],"answer":0,"explanation":"$18x^3\\div 6x^2=3x$, $12x^2\\div 6x^2=2$. 결과: $3x-2$"},
    {"id":16,"question":"$2(a+b)+3(a-b)$를 계산하면?","choices":["$5a-b$","$5a+b$","$5a-5b$","$5a+5b$","$a-b$"],"answer":0,"explanation":"$2a+2b+3a-3b=5a-b$"},
    {"id":17,"question":"$-x(2x^2-3x+1)$을 전개하면?","choices":["$-2x^3+3x^2-x$","$-2x^3-3x^2+x$","$2x^3-3x^2+x$","$-2x^3+3x-1$","$-2x^2+3x-1$"],"answer":0,"explanation":"$-x\\times 2x^2+(-x)\\times(-3x)+(-x)\\times 1=-2x^3+3x^2-x$"},
    {"id":18,"question":"$(6a^2b^2-4a^2b) \\div 2a^2b$를 계산하면?","choices":["$3b-2$","$3b+2$","$3ab-2$","$6b-4$","$3b^2-2b$"],"answer":0,"explanation":"$6a^2b^2\\div 2a^2b=3b$, $4a^2b\\div 2a^2b=2$. 결과: $3b-2$"},
    {"id":19,"question":"$4x(x-3)+2x(1-x)$를 전개하면?","choices":["$2x^2-10x$","$2x^2+10x$","$6x^2-10x$","$2x^2-14x$","$2x-10x$"],"answer":0,"explanation":"$4x^2-12x+2x-2x^2=2x^2-10x$"},
    {"id":20,"question":"$(20a^3b-10a^2b^2) \\div 5a^2b$를 계산하면?","choices":["$4a-2b$","$4a+2b$","$4a^2-2b$","$4a-2ab$","$4-2b$"],"answer":0,"explanation":"$20a^3b\\div 5a^2b=4a$, $10a^2b^2\\div 5a^2b=2b$. 결과: $4a-2b$"},
