    {"id":24,"question":"$-2ab(a-3b+1)$을 전개하면?","choices":["$-2a^2b+6ab^2-2ab$","$-2a^2b-6ab^2+2ab$","$2a^2b-6ab^2-2ab$","$-2a^2b+6ab+2ab$","$-2ab+6ab^2-2b$"],"answer":0,"explanation":"$-2ab\\times a+(-2ab)\\times(-3b)+(-2ab)\\times 1=-2a^2b+6ab^2-2ab$"},
    {"id":25,"question":"$(10x^3y^2-5x^2y+15xy) \\div 5xy$를 계산하면?","choices":["$2x^2y-x+3$","$2x^2y+x-3$","$2xy-x+3$","$2x^2y-x-3$","$2x^2y^2-x+3$"],"answer":0,"explanation":"$10x^3y^2\\div 5xy=2x^2y$, $5x^2y\\div 5xy=x$, $15xy\\div 5xy=3$. 결과: $2x^2y-x+3$"},
    {"id":26,"question":"$x(x+1)-x(x-1)$을 계산하면?","choices":["$2x$","$2x^2$","$2$","$x^2+2x$","$x^2-2x$"],"answer":0,"explanation":"$x^2+x-x^2+x=2x$"},
    {"id":27,"question":"$(8a^2b-4ab+2b) \\div 2b$를 계산하면?","choices":["$4a^2-2a+1$","$4a^2+2a-1$","$4a^2-2a-1$","$4a^2b-2a+1$","$8a^2-4a+2$"],"answer":0,"explanation":"$8a^2b\\div 2b=4a^2$, $4ab\\div 2b=2a$, $2b\\div 2b=1$. 결과: $4a^2-2a+1$"},
