  "difficulty": "기본",
  "questions": [
    {"id":1,"question":"$a^3 \\times a^4$를 계산하면?","choices":["$a^7$","$a^{12}$","$a^1$","$2a^7$","$a^{34}$"],"answer":0,"explanation":"지수법칙: $a^m \\times a^n = a^{m+n}$. $a^3 \\times a^4 = a^7$"},
    {"id":2,"question":"$x^6 \\div x^2$를 계산하면?","choices":["$x^8$","$x^3$","$x^4$","$x^{12}$","$1$"],"answer":2,"explanation":"$x^6 \\div x^2 = x^{6-2} = x^4$"},
    {"id":3,"question":"$(a^2)^3$을 계산하면?","choices":["$a^5$","$a^6$","$a^8$","$2a^3$","$a^{23}$"],"answer":1,"explanation":"$(a^m)^n = a^{mn}$. $(a^2)^3 = a^6$"},
    {"id":4,"question":"$3x^2 \\times 2x^3$을 계산하면?","choices":["$5x^5$","$6x^5$","$6x^6$","$5x^6$","$6x^{23}$"],"answer":1,"explanation":"$3 \\times 2 = 6$, $x^2 \\times x^3 = x^5$. 결과: $6x^5$"},
    {"id":5,"question":"$\\frac{8a^5}{2a^2}$를 계산하면?","choices":["$4a^3$","$4a^7$","$6a^3$","$4a^{52}$","$8a^3$"],"answer":0,"explanation":"$\\frac{8}{2} = 4$, $a^5 \\div a^2 = a^3$. 결과: $4a^3$"},
    {"id":6,"question":"$a^0$의 값은? ($a \\neq 0$)","choices":["$0$","$1$","$a$","$-1$","정의 안됨"],"answer":1,"explanation":"$a^0 = 1$ ($a \\neq 0$)"},
    {"id":7,"question":"$(2x)^3$을 계산하면?","choices":["$2x^3$","$6x^3$","$8x^3$","$8x$","$2x^8$"],"answer":2,"explanation":"$(2x)^3 = 2^3 \\times x^3 = 8x^3$"},
    {"id":8,"question":"$(-a)^4$을 계산하면?","choices":["$-a^4$","$a^4$","$-4a$","$4a$","$a^{-4}$"],"answer":1,"explanation":"지수가 짝수이면 부호가 양. $(-a)^4 = a^4$"},
    {"id":9,"question":"$(-a)^5$을 계산하면?","choices":["$-a^5$","$a^5$","$5a$","$-5a$","$a^{-5}$"],"answer":0,"explanation":"지수가 홀수이면 부호가 음. $(-a)^5 = -a^5$"},
    {"id":10,"question":"$2a^3 \\times 3a^2 \\times a$를 계산하면?","choices":["$6a^5$","$6a^6$","$5a^6$","$6a^7$","$5a^7$"],"answer":1,"explanation":"$2 \\times 3 \\times 1 = 6$, $a^3 \\times a^2 \\times a^1 = a^6$. 결과: $6a^6$"},
    {"id":11,"question":"$\\frac{12x^4y^2}{3x^2y}$를 계산하면?","choices":["$4x^2y$","$4x^2y^2$","$9x^2y$","$4xy$","$4x^6y^3$"],"answer":0,"explanation":"$\\frac{12}{3}=4$, $x^{4-2}=x^2$, $y^{2-1}=y$. 결과: $4x^2y$"},
    {"id":12,"question":"$(ab^2)^3$을 계산하면?","choices":["$ab^6$","$a^3b^6$","$a^3b^5$","$3ab^6$","$a^3b^2$"],"answer":1,"explanation":"$(ab^2)^3 = a^3 \\times (b^2)^3 = a^3b^6$"},
    {"id":13,"question":"$a^5 \\div a^5$를 계산하면?","choices":["$0$","$1$","$a$","$a^{25}$","$a^0$"],"answer":1,"explanation":"$a^5 \\div a^5 = a^0 = 1$"},
    {"id":14,"question":"$(-2x^2)^3$을 계산하면?","choices":["$-8x^6$","$8x^6$","$-6x^5$","$-8x^5$","$8x^5$"],"answer":0,"explanation":"$(-2)^3 = -8$, $(x^2)^3 = x^6$. 결과: $-8x^6$"},
    {"id":15,"question":"$\\frac{a^{10}}{a^4}$을 계산하면?","choices":["$a^6$","$a^{14}$","$a^{40}$","$a^{2.5}$","$a^4$"],"answer":0,"explanation":"$a^{10} \\div a^4 = a^{10-4} = a^6$"},
    {"id":16,"question":"$3x \\times (-2x^2)$를 계산하면?","choices":["$6x^3$","$-6x^3$","$-6x^2$","$6x^2$","$-x^3$"],"answer":1,"explanation":"$3 \\times (-2) = -6$, $x \\times x^2 = x^3$. 결과: $-6x^3$"},
    {"id":17,"question":"$\\left(\\frac{a^2}{b}\\right)^3$을 계산하면?","choices":["$\\frac{a^6}{b^3}$","$\\frac{a^5}{b^3}$","$\\frac{a^6}{b}$","$\\frac{3a^6}{b^3}$","$\\frac{a^2}{b^3}$"],"answer":0,"explanation":"$\\left(\\frac{a^2}{b}\\right)^3 = \\frac{a^6}{b^3}$"},
    {"id":18,"question":"$4x^2y \\times 3xy^2$를 계산하면?","choices":["$12x^3y^3$","$12x^2y^2$","$7x^3y^3$","$12x^3y^2$","$12xy$"],"answer":0,"explanation":"$4 \\times 3 = 12$, $x^2 \\times x = x^3$, $y \\times y^2 = y^3$. 결과: $12x^3y^3$"},
    {"id":19,"question":"$\\frac{6a^3b^2}{2ab}$를 계산하면?","choices":["$3a^2b$","$3a^2b^2$","$4a^2b$","$3ab$","$6a^2b$"],"answer":0,"explanation":"$\\frac{6}{2}=3$, $a^{3-1}=a^2$, $b^{2-1}=b$. 결과: $3a^2b$"},
    {"id":20,"question":"$(3x^2y)^2$를 계산하면?","choices":["$9x^4y^2$","$6x^4y^2$","$9x^2y^2$","$9x^4y$","$3x^4y^2$"],"answer":0,"explanation":"$3^2=9$, $(x^2)^2=x^4$, $y^2=y^2$. 결과: $9x^4y^2$"},
    {"id":21,"question":"$x^3 \\times x^{-1}$을 계산하면?","choices":["$x^4$","$x^2$","$x^{-3}$","$x^3$","$1$"],"answer":1,"explanation":"$x^3 \\times x^{-1} = x^{3+(-1)} = x^2$"},
    {"id":22,"question":"$\\frac{15a^4b^3}{3a^2b}$를 계산하면?","choices":["$5a^2b^2$","$5a^2b^3$","$12a^2b^2$","$5a^6b^4$","$5ab^2$"],"answer":0,"explanation":"$\\frac{15}{3}=5$, $a^{4-2}=a^2$, $b^{3-1}=b^2$. 결과: $5a^2b^2$"},
    {"id":23,"question":"$(-x^2)^4$을 계산하면?","choices":["$-x^8$","$x^8$","$-4x^8$","$x^6$","$-x^6$"],"answer":1,"explanation":"지수 4는 짝수. $(-x^2)^4 = x^8$"},
    {"id":24,"question":"$2a^2 \\times (-3a) \\times a^2$를 계산하면?","choices":["$-6a^5$","$6a^5$","$-5a^5$","$-6a^4$","$6a^4$"],"answer":0,"explanation":"$2 \\times (-3) \\times 1 = -6$, $a^{2+1+2}=a^5$. 결과: $-6a^5$"},
    {"id":25,"question":"$\\frac{(2a)^3}{4a^2}$를 계산하면?","choices":["$2a$","$4a$","$2a^2$","$a$","$2a^3$"],"answer":0,"explanation":"$(2a)^3 = 8a^3$. $\\frac{8a^3}{4a^2} = 2a$"},
    {"id":26,"question":"$a^2 \\times a^3 \\times a^4$의 지수는?","choices":["$6$","$7$","$8$","$9$","$24$"],"answer":3,"explanation":"$2+3+4=9$. $a^9$"},
    {"id":27,"question":"$(-2ab)^2 \\times 3a$를 계산하면?","choices":["$12a^3b^2$","$-12a^3b^2$","$12a^2b^2$","$6a^3b^2$","$12a^3b$"],"answer":0,"explanation":"$(-2ab)^2 = 4a^2b^2$. $4a^2b^2 \\times 3a = 12a^3b^2$"},
    {"id":28,"question":"$\\frac{x^5 \\times x^3}{x^4}$를 계산하면?","choices":["$x^2$","$x^4$","$x^6$","$x^8$","$x^{12}$"],"answer":1,"explanation":"분자: $x^{5+3}=x^8$. $x^8 \\div x^4 = x^4$"},
    {"id":29,"question":"$\\left(\\frac{2x^2}{y}\\right)^2$를 계산하면?","choices":["$\\frac{4x^4}{y^2}$","$\\frac{2x^4}{y^2}$","$\\frac{4x^2}{y^2}$","$\\frac{4x^4}{y}$","$\\frac{4x}{y^2}$"],"answer":0,"explanation":"$\\frac{2^2 x^4}{y^2} = \\frac{4x^4}{y^2}$"},
    {"id":30,"question":"가로 $2x^2$, 세로 $3x$인 직사각형의 넓이는?","choices":["$5x^3$","$6x^3$","$6x^2$","$5x^2$","$6x$"],"answer":1,"explanation":"넓이 $= 2x^2 \\times 3x = 6x^3$"}
  ]
}
