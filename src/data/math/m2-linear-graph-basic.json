{
  "id": "m2-linear-graph-basic",
  "title": "일차함수와 그래프 — 기본",
  "description": "일차함수의 뜻, 기울기, 절편, 그래프 기초",
  "grade": 2,
  "unit": "일차함수",
  "difficulty": "기본",
  "questions": [
    {"id":1,"question":"다음 중 일차함수인 것은?","choices":["$y = x^2 + 1$","$y = \\frac{1}{x}$","$y = 3x - 2$","$y = 0 \\cdot x + 5$","$xy = 4$"],"answer":2,"explanation":"$y = 3x - 2$는 $y = ax + b$ ($a = 3 \\ne 0$) 형태이므로 일차함수. $y = 0 \\cdot x + 5 = 5$는 $a=0$이므로 일차함수 아님."},
    {"id":2,"question":"$y = 4x - 7$의 기울기는?","choices":["$7$","$-7$","$4$","$-4$","$\\frac{7}{4}$"],"answer":2,"explanation":"$y = ax + b$에서 $a$가 기울기. $y = 4x - 7$에서 $a = 4$."},
    {"id":3,"question":"$y = -3x + 5$의 $y$절편은?","choices":["$-3$","$3$","$-5$","$5$","$\\frac{5}{3}$"],"answer":3,"explanation":"$y = ax + b$에서 $b$가 $y$절편. $b = 5$"},
    {"id":4,"question":"$y = 2x - 6$의 $x$절편은?","choices":["$3$","$-3$","$6$","$-6$","$2$"],"answer":0,"explanation":"$x$절편: $y = 0$일 때 $x$. $0 = 2x - 6$ → $x = 3$"},
    {"id":5,"question":"$y = -x + 4$의 $x$절편은?","choices":["$4$","$-4$","$1$","$-1$","$\\frac{1}{4}$"],"answer":0,"explanation":"$0 = -x + 4$ → $x = 4$"},
    {"id":6,"question":"기울기가 $-2$이고 $y$절편이 $3$인 일차함수는?","choices":["$y = 3x - 2$","$y = -2x + 3$","$y = 2x - 3$","$y = -3x + 2$","$y = -2x - 3$"],"answer":1,"explanation":"$y = ax + b$에서 $a = -2$, $b = 3$ → $y = -2x + 3$"},
    {"id":7,"question":"$y = 5x - 3$에서 $x = 2$일 때 $y$의 값은?","choices":["$7$","$10$","$-7$","$13$","$-3$"],"answer":0,"explanation":"$y = 5(2) - 3 = 10 - 3 = 7$"},
    {"id":8,"question":"$y = -x + 5$에서 $x = 3$일 때 $y$의 값은?","choices":["$8$","$-8$","$2$","$-2$","$15$"],"answer":2,"explanation":"$y = -3 + 5 = 2$"},
    {"id":9,"question":"$y = ax + 2$가 점 $(1, 5)$를 지날 때 $a$는?","choices":["$3$","$-3$","$7$","$-7$","$2$"],"answer":0,"explanation":"$5 = a(1) + 2$ → $a = 3$"},
    {"id":10,"question":"$y = 3x + b$가 점 $(2, 1)$을 지날 때 $b$는?","choices":["$-5$","$5$","$7$","$-7$","$1$"],"answer":0,"explanation":"$1 = 3(2) + b$ → $b = 1 - 6 = -5$"},
    {"id":11,"question":"기울기가 양수($a > 0$)인 일차함수의 그래프는?","choices":["오른쪽 위로 향한다 (우상향)","오른쪽 아래로 향한다 (우하향)","$x$축에 평행하다","$y$축에 평행하다","직선이 아니다"],"answer":0,"explanation":"$a > 0$이면 $x$가 증가할 때 $y$도 증가 → 우상향"},
    {"id":12,"question":"$y = -2x + 4$에서 $x$가 $1$ 증가할 때 $y$의 변화량은?","choices":["$-2$","$2$","$-4$","$4$","$0$"],"answer":0,"explanation":"기울기 $a = -2$이므로 $x$가 $1$ 증가할 때 $y$는 $-2$ 변화 (감소)"},
    {"id":13,"question":"$y = 3x - 9$의 $x$절편과 $y$절편의 합은?","choices":["$-6$","$6$","$-12$","$12$","$3$"],"answer":0,"explanation":"$x$절편: $3x = 9$ → $x = 3$. $y$절편: $b = -9$. 합: $3 + (-9) = -6$"},
    {"id":14,"question":"$y = -4x + 8$의 $x$절편은?","choices":["$2$","$-2$","$8$","$-8$","$4$"],"answer":0,"explanation":"$0 = -4x + 8$ → $4x = 8$ → $x = 2$"},
    {"id":15,"question":"두 점 $(0, 3)$, $(1, 5)$를 지나는 직선의 기울기는?","choices":["$2$","$-2$","$3$","$8$","$\\frac{1}{2}$"],"answer":0,"explanation":"$\\frac{5-3}{1-0} = \\frac{2}{1} = 2$"},
    {"id":16,"question":"두 점 $(1, 2)$, $(3, 8)$을 지나는 직선의 기울기는?","choices":["$3$","$-3$","$\\frac{1}{3}$","$5$","$6$"],"answer":0,"explanation":"$\\frac{8-2}{3-1} = \\frac{6}{2} = 3$"},
    {"id":17,"question":"$y = 2x + k$가 점 $(-1, 4)$를 지날 때 $k$는?","choices":["$6$","$-6$","$2$","$-2$","$3$"],"answer":0,"explanation":"$4 = 2(-1) + k$ → $k = 4 + 2 = 6$"},
    {"id":18,"question":"$y = ax - 4$에서 $a > 0$이면 이 그래프는?","choices":["$y$절편이 양수이고 우상향","$y$절편이 음수이고 우상향","$y$절편이 음수이고 우하향","$y$절편이 양수이고 우하향","$x$축에 평행"],"answer":1,"explanation":"$a > 0$ → 우상향. $y$절편 $= -4 < 0$ → $y$절편이 음수"},
    {"id":19,"question":"$y = -\\frac{1}{2}x + 3$의 $y$절편은?","choices":["$3$","$-3$","$\\frac{1}{2}$","$-\\frac{1}{2}$","$6$"],"answer":0,"explanation":"$b = 3$"},
    {"id":20,"question":"$y = -\\frac{1}{2}x + 3$의 $x$절편은?","choices":["$6$","$-6$","$3$","$-3$","$\\frac{3}{2}$"],"answer":0,"explanation":"$0 = -\\frac{1}{2}x + 3$ → $\\frac{1}{2}x = 3$ → $x = 6$"},
    {"id":21,"question":"$y = 3x + b$가 $y$축 위의 점 $(0, -2)$를 지날 때 $b$는?","choices":["$-2$","$2$","$-3$","$3$","$0$"],"answer":0,"explanation":"$y$절편이 곧 $b$. $(0, -2)$이므로 $b = -2$"},
    {"id":22,"question":"다음 중 $y = 2x - 4$의 $y$값이 양수가 되는 $x$의 범위는?","choices":["$x > 2$","$x < 2$","$x > -2$","$x < -2$","$x > 4$"],"answer":0,"explanation":"$2x - 4 > 0$ → $2x > 4$ → $x > 2$"},
    {"id":23,"question":"$y = kx + 2$에서 $x = 3$일 때 $y = -1$이면 $k$는?","choices":["$-1$","$1$","$-3$","$3$","$\\frac{1}{3}$"],"answer":0,"explanation":"$-1 = 3k + 2$ → $3k = -3$ → $k = -1$"},
    {"id":24,"question":"기울기 $2$이고 점 $(3, 7)$을 지나는 직선의 $y$절편은?","choices":["$1$","$-1$","$13$","$-13$","$3$"],"answer":0,"explanation":"$7 = 2(3) + b$ → $b = 7 - 6 = 1$"},
    {"id":25,"question":"$y = -3x + 6$에서 $x$가 $2$ 증가할 때 $y$의 변화량은?","choices":["$-6$","$6$","$-3$","$3$","$-9$"],"answer":0,"explanation":"기울기 $-3$ × $x$ 변화량 $2$ $= -6$"},
    {"id":26,"question":"$y = 2x - 1$과 $y = 2x + 3$의 그래프의 관계는?","choices":["평행","일치","한 점에서 만남","수직","$y$축에 평행"],"answer":0,"explanation":"기울기 모두 $2$이고 $y$절편이 다름 ($-1 \\ne 3$) → 평행"},
    {"id":27,"question":"$y = ax + 3$에서 $a < 0$이면 이 직선이 지나지 않는 사분면은?","choices":["3사분면","1사분면","2사분면","4사분면","없음 (모두 지남)"],"answer":0,"explanation":"$a < 0$ (우하향), $b = 3 > 0$ → 1, 2, 4사분면 통과. 3사분면은 통과하지 않음"},
    {"id":28,"question":"$y = x - 3$이 지나지 않는 사분면은?","choices":["2사분면","1사분면","3사분면","4사분면","모든 사분면 통과"],"answer":0,"explanation":"$a = 1 > 0$ (우상향), $b = -3 < 0$, $x$절편 $= 3 > 0$ → 1, 3, 4사분면 통과. 2사분면 통과 안 함"},
    {"id":29,"question":"$y = 3x$의 그래프는 어떤 점을 지나는가?","choices":["원점 $(0, 0)$","$(1, 0)$","$(0, 3)$","$(3, 0)$","$(1, -3)$"],"answer":0,"explanation":"$y = 3x$는 $b = 0$이므로 원점을 지남"},
    {"id":30,"question":"$y = -2x + b$가 $x$축에서 $x = 3$인 점을 지날 때 $b$는?","choices":["$6$","$-6$","$3$","$-3$","$2$"],"answer":0,"explanation":"점 $(3, 0)$을 지남. $0 = -2(3) + b$ → $b = 6$"}
  ]
}
