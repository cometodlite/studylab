  "difficulty": "유형별",
  "questions": [
    {"id":1,"question":"$y = ax + b$의 그래프가 두 점 $(1, 1)$, $(3, 5)$를 지날 때 $a + b$는?","choices":["$1$","$3$","$-1$","$5$","$2$"],"answer":0,"explanation":"기울기 $= (5-1)/(3-1) = 2$. $1 = 2+b$ → $b=-1$. $a+b=2+(-1)=1$"},
    {"id":2,"question":"$3x - 2y + 6 = 0$의 기울기와 $y$절편의 곱은?","choices":["$\\frac{9}{2}$","$-\\frac{9}{2}$","$9$","$-9$","$3$"],"answer":0,"explanation":"$y = \\frac{3}{2}x + 3$. 기울기 $\\times$ $y$절편 $= \\frac{3}{2} \\times 3 = \\frac{9}{2}$"},
    {"id":3,"question":"$y = -2x + 6$을 $x$축 방향으로 $3$ 이동한 직선의 $y$절편은?","choices":["$12$","$-12$","$0$","$6$","$-6$"],"answer":0,"explanation":"$y = -2(x-3)+6 = -2x+6+6 = -2x+12$. $y$절편 $= 12$"},
    {"id":4,"question":"$4x + 3y = 12$의 $x$절편과 $y$절편의 합은?","choices":["$7$","$-7$","$3$","$4$","$12$"],"answer":0,"explanation":"$x$절편: $y=0$ → $x=3$. $y$절편: $x=0$ → $y=4$. 합 $= 7$"},
    {"id":5,"question":"$y = 2x + a$와 $y = bx + 3$이 일치할 때 $ab$는?","choices":["$6$","$-6$","$2$","$3$","$0$"],"answer":0,"explanation":"일치 → $b=2$이고 $a=3$. $ab=6$"},
    {"id":6,"question":"두 직선 $y = x + 2$, $y = -x + 6$의 교점의 좌표는?","choices":["$(2, 4)$","$(4, 2)$","$(3, 5)$","$(1, 3)$","$(6, 0)$"],"answer":0,"explanation":"$x+2=-x+6$ → $2x=4$ → $x=2$, $y=4$"},
    {"id":7,"question":"$y = 3x + k$가 두 점 $(-1, 0)$과 $(1, q)$를 지날 때 $k + q$는?","choices":["$6$","$-6$","$3$","$-3$","$0$"],"answer":0,"explanation":"$0 = 3(-1)+k$ → $k=3$. $q=3(1)+3=6$. $k+q=9$. 정답: $9$."},
    {"id":8,"question":"$y = -\\frac{3}{4}x + 3$의 $x$절편은?","choices":["$4$","$-4$","$3$","$-3$","$\\frac{4}{3}$"],"answer":0,"explanation":"$0 = -\\frac{3}{4}x+3$ → $x=4$"},
    {"id":9,"question":"$5x - y - 10 = 0$의 기울기는?","choices":["$5$","$-5$","$10$","$-10$","$\\frac{1}{5}$"],"answer":0,"explanation":"$y = 5x - 10$. 기울기 $= 5$"},
    {"id":10,"question":"$y = 2x + 3$과 $y = ax + b$가 $y$축 위에서 만날 때 $b$는?","choices":["$3$","$-3$","$2$","$a$","$0$"],"answer":0,"explanation":"$y$축($x=0$): $y=3$이므로 교점 $(0,3)$. $b=3$"},
    {"id":11,"question":"$y = kx - 2$의 그래프가 점 $(-2, 4)$를 지날 때 이 직선의 $x$절편은?","choices":["$\\frac{1}{3}$","$-\\frac{1}{3}$","$3$","$-3$","$1$"],"answer":0,"explanation":"$4=-2k-2$ → $k=-3$. $y=-3x-2$. $x$절편: $0=-3x-2$ → $x=-2/3$. 정답: $-\\frac{2}{3}$."},
    {"id":12,"question":"연립방정식 $\\begin{cases} 2x - y = 3 \\\\ x + y = 6 \\end{cases}$의 해는?","choices":["$(3, 3)$","$(3, -3)$","$(1, 5)$","$(6, 0)$","$(2, 4)$"],"answer":0,"explanation":"합: $3x = 9$ → $x=3$, $y=3$"},
    {"id":13,"question":"$y = (a-1)x + (b+2)$가 $y$축에 평행하려면?","choices":["$a = 1$","$a = -1$","$b = -2$","$a = 0$","$b = 0$"],"answer":0,"explanation":"$y$축에 평행 → $y = 상수$ → 기울기 $0$. $a-1=0$ → $a=1$"},
    {"id":14,"question":"$y = 2x - 5$와 $y = -3x + 5$의 교점의 $y$좌표는?","choices":["$-1$","$1$","$-5$","$5$","$0$"],"answer":0,"explanation":"$2x-5=-3x+5$ → $5x=10$ → $x=2$, $y=-1$"},
    {"id":15,"question":"$x = -3$과 $y = 2x + 5$의 교점은?","choices":["$(-3, -1)$","$(-1, -3)$","$(3, 11)$","$(-3, 1)$","$(-3, 11)$"],"answer":0,"explanation":"$x=-3$: $y=2(-3)+5=-1$. 교점 $(-3,-1)$"},
    {"id":16,"question":"$y = 4x + b$의 그래프가 $y = -x + 7$과 $y$축 위에서 만날 때 $b$는?","choices":["$7$","$-7$","$4$","$-4$","$0$"],"answer":0,"explanation":"$y$축 위($x=0$): $y=7$. $b=7$"},
    {"id":17,"question":"$y = \\frac{2}{3}x - 4$의 그래프와 $y$축, $x$축으로 만드는 삼각형의 넓이는?","choices":["$12$","$6$","$24$","$3$","$8$"],"answer":0,"explanation":"$x$절편 $= 6$, $y$절편 $= -4$. 넓이 $= \\frac{1}{2} \\times 6 \\times 4 = 12$"},
    {"id":18,"question":"$y = -x + k$의 그래프를 $y$축 방향으로 $-2$ 이동하면 점 $(1, 0)$을 지날 때 $k$는?","choices":["$3$","$-3$","$1$","$-1$","$2$"],"answer":0,"explanation":"이동 후: $y = -x + (k-2)$. 점 $(1,0)$: $0=-1+(k-2)$ → $k=3$"},
    {"id":19,"question":"$y = -2x + a$와 $y = bx - 4$가 한 점에서 만나고 그 점이 $(2, -2)$이면 $a + b$는?","choices":["$1$","$-1$","$3$","$-3$","$5$"],"answer":0,"explanation":"$-2 = -4+a$ → $a=2$. $-2=2b-4$ → $b=1$. $a+b=3$. 정답: $3$ (index 2)."},
    {"id":20,"question":"$3x + 4y - 12 = 0$의 $y$절편에서 $y = -x + b$가 같은 $y$절편을 가질 때 $b$는?","choices":["$3$","$-3$","$4$","$-4$","$12$"],"answer":2,"explanation":"$3x+4y=12$ → $y=(-3/4)x+3$. $y$절편 $=3$. $y=-x+b$도 $y$절편 $3$ → $b=3$."},
    {"id":21,"question":"$y = -3x + 9$와 $y = ax + 1$의 교점의 $x$좌표가 $2$일 때 $a$는?","choices":["$\\frac{3}{2}$","$-\\frac{3}{2}$","$3$","$-3$","$\\frac{1}{2}$"],"answer":0,"explanation":"$x=2$에서 $y=-6+9=3$. $3=2a+1$ → $a=1$. 정답: $1$."},
    {"id":22,"question":"$y = 2x + 3$을 $x$축 방향으로 $-1$, $y$축 방향으로 $+2$ 이동하면?","choices":["$y = 2x + 7$","$y = 2x - 7$","$y = 2x + 3$","$y = 4x + 3$","$y = 2x + 5$"],"answer":0,"explanation":"$y = 2(x+1)+3+2 = 2x+2+3+2 = 2x+7$"},
    {"id":23,"question":"$y = x + k$와 $y = 3x - 2$의 교점의 $y$좌표가 $4$이면 $k$는?","choices":["$1$","$-1$","$3$","$-3$","$4$"],"answer":0,"explanation":"교점 $y=4$: $y=3x-2=4$ → $x=2$. $4=2+k$ → $k=2$. 정답: $2$."},
    {"id":24,"question":"$y = -x + a$와 $y = 2x + b$의 교점이 $(1, 3)$일 때 $a - b$는?","choices":["$3$","$-3$","$1$","$-1$","$0$"],"answer":0,"explanation":"$3=-1+a$ → $a=4$. $3=2+b$ → $b=1$. $a-b=3$"},
    {"id":25,"question":"$6x - 4y - 8 = 0$을 $y$에 대해 풀면?","choices":["$y = \\frac{3}{2}x - 2$","$y = \\frac{3}{2}x + 2$","$y = -\\frac{3}{2}x - 2$","$y = 2x - 8$","$y = \\frac{2}{3}x - 2$"],"answer":0,"explanation":"$4y = 6x - 8$ → $y = \\frac{3}{2}x - 2$"},
    {"id":26,"question":"$y = 4$와 $y = -2x + 8$의 교점은?","choices":["$(2, 4)$","$(4, 2)$","$(8, 4)$","$(0, 4)$","$(4, 0)$"],"answer":0,"explanation":"$4=-2x+8$ → $2x=4$ → $x=2$. 교점 $(2,4)$"},
    {"id":27,"question":"$y = ax + 2$의 그래프가 $(-4, 0)$을 지날 때 이 직선의 기울기는?","choices":["$\\frac{1}{2}$","$-\\frac{1}{2}$","$2$","$-2$","$4$"],"answer":0,"explanation":"$0=-4a+2$ → $a=1/2$"},
    {"id":28,"question":"$y = \\frac{1}{3}x + m$이 $y = 2x - 5$와 $x = 3$에서 만날 때 $m$은?","choices":["$0$","$-1$","$1$","$-2$","$2$"],"answer":0,"explanation":"$y=2(3)-5=1$이고 $1=1+m$ → $m=0$"},
    {"id":29,"question":"$y = -x + c$와 $y = x - 3$의 교점의 $x$좌표가 $2$이면 $c$는?","choices":["$1$","$-1$","$3$","$-3$","$2$"],"answer":0,"explanation":"$x=2$: $y=2-3=-1$. $-1=-2+c$ → $c=1$"},
    {"id":30,"question":"$y = 3x + 5$와 $y = -x + 1$의 교점에서 $x + y$의 값은?","choices":["$1$","$-1$","$3$","$0$","$2$"],"answer":0,"explanation":"$3x+5=-x+1$ → $4x=-4$ → $x=-1$, $y=2$. $x+y=1$"}
  ]
