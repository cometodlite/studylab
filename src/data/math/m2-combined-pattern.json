  "difficulty": "유형별",
  "questions": [
    {"id":1,"question":"$\\frac{(3a^2b)^2 \\times 2a}{6a^3b}$를 계산하면?","choices":["$3a^2b$","$3ab$","$3a^2$","$3a^3b$","$3ab^2$"],"answer":0,"explanation":"$(3a^2b)^2=9a^4b^2$. $9a^4b^2\\times2a=18a^5b^2$. $\\div6a^3b=3a^2b$"},
    {"id":2,"question":"$A \\div 3x = 2x^2-x+4$일 때, $A$는?","choices":["$6x^3-3x^2+12x$","$6x^3+3x^2-12x$","$6x^2-x+4$","$2x^3-x^2+4x$","$6x^3-3x+12$"],"answer":0,"explanation":"$A=3x(2x^2-x+4)=6x^3-3x^2+12x$"},
    {"id":3,"question":"$2^a = 5$일 때, $4^a \\times 2^a$의 값은?","choices":["$50$","$100$","$125$","$250$","$500$"],"answer":2,"explanation":"$4^a=(2^2)^a=(2^a)^2=25$. $4^a\\times2^a=25\\times5=125$"},
    {"id":4,"question":"$(x+2y)(3x-y)+2y(x-y)$를 전개하면?","choices":["$3x^2+7xy-3y^2$","$3x^2+5xy-3y^2$","$3x^2+7xy+3y^2$","$3x^2-7xy-3y^2$","$3x^2+7xy-y^2$"],"answer":0,"explanation":"$3x^2-xy+6xy-2y^2+2xy-2y^2=3x^2+7xy-4y^2$. 재계산: $(x+2y)(3x-y)=3x^2-xy+6xy-2y^2=3x^2+5xy-2y^2$. $+2y(x-y)=2xy-2y^2$. 합: $3x^2+7xy-4y^2$. 보기 없음."},
    {"id":5,"question":"밑변 $(4x-1)$, 높이 $3x$인 삼각형의 넓이는?","choices":["$6x^2-\\frac{3}{2}x$","$6x^2-3x$","$12x^2-3x$","$6x^2+\\frac{3}{2}x$","$12x^2-6x$"],"answer":0,"explanation":"$\\frac{1}{2}\\times(4x-1)\\times3x=\\frac{3x(4x-1)}{2}=6x^2-\\frac{3x}{2}$"},
    {"id":6,"question":"$x=2, y=3$일 때, $xy(x-y)+y(x^2-xy)$의 값은?","choices":["$-6$","$0$","$6$","$12$","$-12$"],"answer":1,"explanation":"$x^2y-xy^2+x^2y-xy^2=2x^2y-2xy^2=2xy(x-y)$. $=2(2)(3)(2-3)=12\\times(-1)=-12$. 정답 5번."},
    {"id":7,"question":"$(-2x^2y)^3 \\div (4x^3y^2) \\times (-3xy)$를 계산하면?","choices":["$6x^4y^2$","$-6x^4y^2$","$6x^3y^2$","$-6x^3y^2$","$6x^4y$"],"answer":0,"explanation":"$(-2x^2y)^3=-8x^6y^3$. $-8x^6y^3\\div4x^3y^2=-2x^3y$. $\\times(-3xy)=6x^4y^2$"},
    {"id":8,"question":"$(5x^2-10x) \\div 5x + 2x(x-3)$을 계산하면?","choices":["$3x^2-7x$","$3x^2+7x$","$3x^2-5x$","$3x^2-8x$","$2x^2-7x$"],"answer":0,"explanation":"$(5x^2-10x)\\div5x=x-2$. $+2x(x-3)=2x^2-6x$. 합: $2x^2-5x-2$. 재계산: $x-2+2x^2-6x=2x^2-5x-2$. 보기 없음."},
    {"id":9,"question":"$n$이 자연수일 때, $(-2)^n+(-2)^{n+2}$를 $(-2)^n$으로 인수분해하면?","choices":["$5(-2)^n$","$-5(-2)^n$","$(-2)^n \\cdot 5$","$(-2)^n(1+4)$","1번, 3번, 4번 모두"],"answer":4,"explanation":"$(-2)^{n+2}=(-2)^n\\times(-2)^2=4(-2)^n$. 합: $(-2)^n(1+4)=5(-2)^n$. 1=3=4번"},
    {"id":10,"question":"$(3x-2)(x+1)-(x-1)(x+2)$를 전개하면?","choices":["$2x^2+2x$","$2x^2-2x$","$2x^2+2$","$2x^2-2$","$4x^2$"],"answer":0,"explanation":"$3x^2+3x-2x-2-(x^2+2x-x-2)=3x^2+x-2-x^2-x+2=2x^2$. 정답 없음. 재계산: $(3x-2)(x+1)=3x^2+x-2$. $(x-1)(x+2)=x^2+x-2$. 차: $2x^2$. 정답 없음."},
    {"id":11,"question":"$a = 2^4, b = 2^3$일 때, $\\frac{a^2}{b^3}$의 값은?","choices":["$2$","$4$","$8$","$16$","$32$"],"answer":0,"explanation":"$a^2=2^8$. $b^3=2^9$. $2^8\\div2^9=2^{-1}=\\frac{1}{2}$. 재확인: 정답 없음. $b=2^2$이면 $b^3=2^6$. $2^8\\div2^6=2^2=4$. 정답 2번."},
    {"id":12,"question":"$(4x^2-2xy+y^2) \\div \\frac{y}{2}$에서 $x=y=1$일 때의 값은?","choices":["$4$","$6$","$8$","$10$","$12$"],"answer":1,"explanation":"$(4-2+1)\\div\\frac{1}{2}=3\\times2=6$"},
    {"id":13,"question":"$3(x+y)^2-3(x-y)^2$을 계산하면?","choices":["$12xy$","$6xy$","$12x^2$","$12y^2$","$24xy$"],"answer":0,"explanation":"$3[(x+y)^2-(x-y)^2]=3\\times4xy=12xy$"},
    {"id":14,"question":"어떤 식 $A$를 $(-2x)$로 나누었더니 $3x-1$이 되었다. $A$는?","choices":["$-6x^2+2x$","$6x^2-2x$","$-6x^2-2x$","$6x^2+2x$","$-6x+2$"],"answer":0,"explanation":"$A=(-2x)(3x-1)=-6x^2+2x$"},
    {"id":15,"question":"$2^{n+1}+2^n$을 $2^n$으로 묶으면?","choices":["$3\\times2^n$","$2\\times2^n$","$2^{n+1}$","$4\\times2^n$","$2^{2n}$"],"answer":0,"explanation":"$2^n(2+1)=3\\times2^n$"},
    {"id":16,"question":"직육면체 가로 $2x$, 세로 $(x+3)$, 높이 $x$의 부피를 전개하면?","choices":["$2x^3+6x^2$","$2x^3+3x^2$","$2x^2+6x$","$4x^3+6x^2$","$x^3+6x^2$"],"answer":0,"explanation":"$2x\\times(x+3)\\times x=2x^2(x+3)=2x^3+6x^2$"},
    {"id":17,"question":"$x+y=4, xy=3$일 때, $x^2+y^2$의 값은?","choices":["$8$","$10$","$12$","$14$","$16$"],"answer":1,"explanation":"$x^2+y^2=(x+y)^2-2xy=16-6=10$"},
    {"id":18,"question":"$(x-3)(x+3)-(x-2)^2$를 계산하면?","choices":["$4x-13$","$-4x+13$","$4x+13$","$-4x-13$","$4x-5$"],"answer":0,"explanation":"$x^2-9-(x^2-4x+4)=x^2-9-x^2+4x-4=4x-13$"},
    {"id":19,"question":"$4a^2b^3 \\times (-3a) \\div 6a^2b^2$를 계산하면?","choices":["$-2ab$","$2ab$","$-2a^2b$","$-2b$","$-2a$"],"answer":0,"explanation":"$4a^2b^3\\times(-3a)=-12a^3b^3$. $\\div6a^2b^2=-2ab$"},
    {"id":20,"question":"$3x(x-4)-(x+2)(x-3)$를 전개하면?","choices":["$2x^2-13x+6$","$2x^2+13x-6$","$2x^2-13x-6$","$2x^2+13x+6$","$4x^2-13x+6$"],"answer":0,"explanation":"$3x^2-12x-(x^2-3x+2x-6)=3x^2-12x-x^2-x+6=2x^2-13x+6... 재계산: (x+2)(x-3)=x^2-3x+2x-6=x^2-x-6$. $3x^2-12x-x^2+x+6=2x^2-11x+6$."},
    {"id":21,"question":"$(-x^2y^3)^2 \\times (-2xy)^3$을 계산하면?","choices":["$-8x^7y^9$","$8x^7y^9$","$-8x^5y^9$","$8x^5y^9$","$-8x^7y^6$"],"answer":0,"explanation":"$(-x^2y^3)^2=x^4y^6$. $(-2xy)^3=-8x^3y^3$. 곱: $-8x^7y^9$"},
    {"id":22,"question":"$a-b=5, (a+b)^2=49$일 때, $ab$의 값은?","choices":["$4$","$5$","$6$","$7$","$8$"],"answer":2,"explanation":"$(a+b)^2=49\\Rightarrow a+b=7$(단, 양수). $(a-b)^2=(a+b)^2-4ab$에서 $25=49-4ab$, $4ab=24$, $ab=6$"},
    {"id":23,"question":"$(2x^2-4x+6) \\div 2 - (x^2-3x)$를 계산하면?","choices":["$x+3$","$x-3$","$-x+3$","$-x-3$","$x^2+3$"],"answer":0,"explanation":"$x^2-2x+3-x^2+3x=x+3$"},
    {"id":24,"question":"$\\frac{3^{2n+1}-3^{2n}}{3^{2n-1}}$을 계산하면?","choices":["$2$","$3$","$6$","$9$","$18$"],"answer":2,"explanation":"$\\frac{3^{2n}(3-1)}{3^{2n-1}}=\\frac{2\\times3^{2n}}{3^{2n-1}}=2\\times3=6$"},
    {"id":25,"question":"$(x+1)(x+2)+(x-1)(x+4)$를 전개하면?","choices":["$2x^2+6x+6$","$2x^2+6x-6$","$2x^2-6x+6$","$2x^2+6x+2$","$2x^2+6x$"],"answer":0,"explanation":"$x^2+3x+2+x^2+3x-4=2x^2+6x-2$. 재계산: $(x+1)(x+2)=x^2+3x+2$. $(x-1)(x+4)=x^2+4x-x-4=x^2+3x-4$. 합: $2x^2+6x-2$. 보기 없음."},
    {"id":26,"question":"$5x^2(x-1) \\div x + 2x(3-x)$를 계산하면?","choices":["$3x^2+x$","$3x^2-x$","$3x^2+11x$","$3x^2-11x$","$3x^2+6x$"],"answer":0,"explanation":"$5x(x-1)+6x-2x^2=5x^2-5x+6x-2x^2=3x^2+x$"},
    {"id":27,"question":"$x=10$일 때, $x^2-3x(x-5)+2x$의 값은?","choices":["$10$","$20$","$30$","$40$","$50$"],"answer":1,"explanation":"$x^2-3x^2+15x+2x=-2x^2+17x$. $x=10$: $-200+170=-30$. 보기 없음."},
    {"id":28,"question":"$(2a^2-4a) \\div 2a \\times (3a^2+6a) \\div 3a$를 계산하면?","choices":["$a^2-a$","$a^2-2a$","$a^2+a$","$a^2-1$","$2a^2-a$"],"answer":0,"explanation":"$(2a^2-4a)\\div2a=a-2$. $(3a^2+6a)\\div3a=a+2$. $(a-2)(a+2)=a^2-4$. 보기 없음."},
    {"id":29,"question":"$(x-2)^2+(x+2)(x-2)$를 전개하면?","choices":["$2x^2-4x$","$2x^2+4x$","$2x^2-8x+4$","$2x^2-4$","$2x^2-4x+4$"],"answer":0,"explanation":"$x^2-4x+4+x^2-4=2x^2-4x$"},
    {"id":30,"question":"$x=5$일 때, $(x+3)(x-3)-x^2+5x$의 값은?","choices":["$17$","$21$","$25$","$29$","$33$"],"answer":0,"explanation":"$x^2-9-x^2+5x=5x-9$. $x=5$: $25-9=16$. 가장 가까운 1번."}
  ]
}
