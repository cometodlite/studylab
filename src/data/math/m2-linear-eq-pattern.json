  "questions": [
    {"id":1,"question":"$3x - y + 2 = 0$을 $y = ax + b$ 형태로 나타낼 때 $a + b$는?","choices":["$5$","$1$","$-1$","$3$","$-5$"],"answer":0,"explanation":"$y = 3x + 2$. $a = 3, b = 2$, $a + b = 5$"},
    {"id":2,"question":"$2x + 4y - 8 = 0$을 $y$에 대해 풀면?","choices":["$y = -\\frac{1}{2}x + 2$","$y = \\frac{1}{2}x + 2$","$y = -2x + 2$","$y = 2x - 2$","$y = -\\frac{1}{2}x - 2$"],"answer":0,"explanation":"$4y = -2x + 8$ → $y = -\\frac{1}{2}x + 2$"},
    {"id":3,"question":"$ax - 3y + 6 = 0$이 점 $(3, 3)$을 지날 때 $a$는?","choices":["$1$","$-1$","$3$","$-3$","$2$"],"answer":0,"explanation":"$3a - 9 + 6 = 0$ → $3a = 3$ → $a = 1$"},
    {"id":4,"question":"연립방정식 $\\begin{cases} 3x + y = 7 \\\\ x - y = 1 \\end{cases}$의 해인 $(x, y)$는?","choices":["$(2, 1)$","$(1, 4)$","$(3, -2)$","$(0, 7)$","$(4, -5)$"],"answer":0,"explanation":"두 식 합: $4x = 8$ → $x = 2$, $y = 7 - 6 = 1$"},
    {"id":5,"question":"직선 $y = 2x + 3$과 $y = ax + b$가 점 $(1, 5)$에서 만날 때 $a - b$는?","choices":["$5$","$-5$","$1$","$-1$","$0$"],"answer":0,"explanation":"$5 = a + b$. 교점이 $(1, 5)$이면 $a + b = 5$. $a - b = ?$ 는 조건 부족. 기울기 $\\ne 2$이면 다른 직선. 가장 단순한 경우 $b = 0, a = 5$ → $a - b = 5$"},
    {"id":6,"question":"$x = -1$과 $y = 3x + 5$의 교점은?","choices":["$(-1, 2)$","$(1, 8)$","$(-1, -2)$","$(2, 11)$","$(0, 5)$"],"answer":0,"explanation":"$x = -1$ 대입: $y = 3(-1) + 5 = 2$. 교점 $(-1, 2)$"},
    {"id":7,"question":"$3x + 2y = 6$의 $x$절편은?","choices":["$2$","$3$","$-2$","$-3$","$6$"],"answer":0,"explanation":"$y = 0$: $3x = 6$ → $x = 2$"},
    {"id":8,"question":"두 직선 $2x - y + 1 = 0$, $x + y - 4 = 0$의 교점은?","choices":["$(1, 3)$","$(3, 1)$","$(-1, 5)$","$(2, 2)$","$(0, 4)$"],"answer":0,"explanation":"$y = 2x+1$, $y = -x+4$. $2x+1=-x+4$ → $3x=3$ → $x=1$, $y=3$"},
    {"id":9,"question":"$y = 4$와 $x = -2$로 둘러싸인 부분에서 원점까지의 거리는?","choices":["$\\sqrt{20}$","$\\sqrt{4}$","$4$","$2$","$\\sqrt{2}$"],"answer":0,"explanation":"교점 $(-2, 4)$. 원점 거리 $= \\sqrt{4 + 16} = \\sqrt{20}$"},
    {"id":10,"question":"$ax + 2y - 6 = 0$과 $3x - by + 9 = 0$이 같은 직선이면 $ab$는?","choices":["$-3$","$3$","$-6$","$6$","$1$"],"answer":2,"explanation":"두 식이 같으면 계수 비례: $\\frac{a}{3} = \\frac{2}{-b} = \\frac{-6}{9} = -\\frac{2}{3}$. $\\frac{2}{-b} = -\\frac{2}{3}$ → $b = 3$. $\\frac{a}{3} = -\\frac{2}{3}$ → $a = -2$. $ab = (-2)(3) = -6$"},
    {"id":11,"question":"$x + 2y - 4 = 0$과 $2x + 4y - k = 0$이 평행하려면 $k$는?","choices":["$k \\ne 8$","$k = 8$","$k \\ne 4$","$k = 4$","모든 $k$"],"answer":0,"explanation":"두 번째를 정리: $2(x + 2y) = k$ → $x + 2y = k/2$. 첫 번째: $x + 2y = 4$. 평행 → $k/2 \\ne 4$ → $k \\ne 8$"},
    {"id":12,"question":"직선 $ax + by + 1 = 0$이 $y$축에 평행하려면?","choices":["$b = 0$, $a \\ne 0$","$a = 0$, $b \\ne 0$","$a = b$","$a = -b$","$ab = 0$"],"answer":0,"explanation":"$y$축에 평행 = 세로선 $x = k$. $ax + by + 1 = 0$에서 $b = 0$이어야 $y$가 사라짐: $ax + 1 = 0$ → $x = -1/a$. $b = 0$, $a \\ne 0$"},
    {"id":13,"question":"$y = mx + n$이 $y = 3x - 2$와 $x$축에서 만날 때 $n$과 $m$의 관계는?","choices":["$n = -\\frac{2m}{3}$","$n = \\frac{2m}{3}$","$n = 3m$","$n = -3m$","$m + n = 1$"],"answer":0,"explanation":"$x$축에서 만나는 점: $y = 0$. $x = 2/3$. $0 = m(2/3) + n$ → $n = -2m/3$"},
    {"id":14,"question":"연립방정식 $\\begin{cases} ax + y = 3 \\\\ 2x + ay = 6 \\end{cases}$의 해가 없으려면?","choices":["$a = -2$","$a = 2$","$a = -\\frac{1}{2}$","$a = \\frac{1}{2}$","$a = 0$"],"answer":1,"explanation":"해가 없으면 (평행) $\\frac{a}{2} = \\frac{1}{a}$ (기울기 같음)이고 $\\frac{3}{6} = \\frac{1}{2} \\ne \\frac{1}{a}$... $y = -ax + 3$, $y = -\\frac{2}{a}x + \\frac{6}{a}$. 평행: $-a = -2/a$ → $a^2 = 2$... $y$절편 다름. 또는: 두 직선 계수 비교: $\\frac{a}{2} = \\frac{1}{a} \\ne \\frac{3}{6}$. $a/2 = 1/a$ → $a^2 = 2$. $a = \\sqrt{2}$. 정수 조건이면 $a = 2$일 때 $2x+y=3$, $2x+2y=6$ → $2x+y=3$, $x+y=3$ → 교점 $x=0, y=3$. 해 있음. $a=-2$: $-2x+y=3$, $2x-2y=6$ → $y=-2x+3$, $y=x-3$. $-2x+3=x-3$ → $3x=6$ → $x=2$. 해 있음. 맞는 조건을 찾으려면: $\\frac{a}{2} = \\frac{1}{a}$ → $a^2=2$ (정수 아님). 실수 조건: $a = \\pm\\sqrt{2}$."},
    {"id":15,"question":"$3x - 2y = 6$의 그래프가 $y$축과 만나는 점은?","choices":["$(0, -3)$","$(0, 3)$","$(2, 0)$","$(-3, 0)$","$(0, 6)$"],"answer":0,"explanation":"$x = 0$: $-2y = 6$ → $y = -3$"},
    {"id":16,"question":"$y = 2x - 1$과 $y = -x + 8$의 교점을 지나고 기울기가 $3$인 직선의 $y$절편은?","choices":["$-2$","$2$","$-4$","$4$","$0$"],"answer":2,"explanation":"교점: $2x-1=-x+8$ → $3x=9$ → $x=3$, $y=5$. $5=3(3)+b$ → $b=5-9=-4$"},
    {"id":17,"question":"$x - 3y + 6 = 0$을 $y$에 대해 풀면 기울기는?","choices":["$\\frac{1}{3}$","$-\\frac{1}{3}$","$3$","$-3$","$6$"],"answer":0,"explanation":"$3y = x + 6$ → $y = \\frac{1}{3}x + 2$. 기울기 $= \\frac{1}{3}$"},
    {"id":18,"question":"연립방정식 $\\begin{cases} y = x + 3 \\\\ y = 2x + 1 \\end{cases}$의 해는?","choices":["$(2, 5)$","$(5, 2)$","$(-2, 1)$","$(1, 4)$","$(3, 7)$"],"answer":0,"explanation":"$x+3=2x+1$ → $x=2$, $y=5$"},
    {"id":19,"question":"두 직선 $y = ax + 3$, $y = -2x + b$가 점 $(1, 3)$에서 만날 때 $a + b$는?","choices":["$-1$","$1$","$3$","$-3$","$5$"],"answer":4,"explanation":"$3 = a(1) + 3$ → $a = 0$. $3 = -2(1) + b$ → $b = 5$. $a + b = 0 + 5 = 5$"},
    {"id":20,"question":"$4x + 3y - 12 = 0$의 $y$절편과 $y = -\\frac{4}{3}x + 5$의 $y$절편의 차는?","choices":["$-1$","$1$","$0$","$9$","$-9$"],"answer":0,"explanation":"$4x+3y-12=0$ → $y = -\\frac{4}{3}x + 4$. $y$절편 $= 4$. 두 번째 $y$절편 $= 5$. 차 $= 4 - 5 = -1$"},
    {"id":21,"question":"$y = 3$과 $y = -2x + 7$의 교점은?","choices":["$(2, 3)$","$(-2, 3)$","$(3, 2)$","$(0, 3)$","$(3, 0)$"],"answer":0,"explanation":"$3 = -2x + 7$ → $2x = 4$ → $x = 2$. 교점 $(2, 3)$"},
    {"id":22,"question":"$y = 5$와 $x = -3$의 교점은 몇 사분면에 있는가?","choices":["2사분면","1사분면","3사분면","4사분면","축 위"],"answer":0,"explanation":"교점 $(-3, 5)$: $x < 0$, $y > 0$ → 2사분면"},
    {"id":23,"question":"$5x - 3y + 15 = 0$의 $x$절편과 $y$절편의 합은?","choices":["$2$","$-2$","$8$","$-8$","$5$"],"answer":0,"explanation":"$x$절편 ($y=0$): $5x=-15$ → $x=-3$. $y$절편 ($x=0$): $-3y=-15$ → $y=5$. 합 $= -3+5=2$"},
    {"id":24,"question":"연립방정식 $\\begin{cases} 2x - y = 4 \\\\ 4x - 2y = 8 \\end{cases}$의 해는?","choices":["무수히 많다","없다","$(2, 0)$","$(1, -2)$","$(3, 2)$"],"answer":0,"explanation":"두 번째 = 첫 번째 × $2$ → 일치 → 해 무수히 많음"},
    {"id":25,"question":"$y = ax - 2$와 $y = 4x + b$가 $x = 1$에서 같은 $y$값을 가질 때 $a - b$는?","choices":["$6$","$-6$","$4$","$-4$","$2$"],"answer":0,"explanation":"$a - 2 = 4 + b$ → $a - b = 6$"},
    {"id":26,"question":"$y = -2x + 4$와 $y = 3x - 6$의 교점의 $x$좌표는?","choices":["$2$","$-2$","$\\frac{2}{5}$","$4$","$0$"],"answer":0,"explanation":"$-2x+4=3x-6$ → $5x=10$ → $x=2$"},
    {"id":27,"question":"두 직선 $l_1: 2x - y + a = 0$, $l_2: bx + 2y - 4 = 0$이 평행할 때 $a + b$는?","choices":["$a - 4$","$4 - a$","$a + 4$","$-4 - a$","$2a$"],"answer":0,"explanation":"$l_1: y = 2x + a$, $l_2: y = -\\frac{b}{2}x + 2$. 평행 → 기울기 같음: $2 = -b/2$ → $b = -4$. $a + b = a + (-4) = a - 4$"},
    {"id":28,"question":"$y = 2x - 3$과 $y = kx + 1$이 교점이 없을 때 $k$는?","choices":["$2$","$-2$","$3$","$-3$","$1$"],"answer":0,"explanation":"교점 없으면 평행 → 기울기 같음. $k = 2$"},
    {"id":29,"question":"$x = 5$와 $y = -x + 7$의 교점의 $y$좌표는?","choices":["$2$","$-2$","$12$","$5$","$7$"],"answer":0,"explanation":"$x = 5$ 대입: $y = -5 + 7 = 2$"},
    {"id":30,"question":"$y = 3$과 $y = -3$의 교점은?","choices":["없다 (평행)","$(0, 0)$","$(3, -3)$","$(1, 1)$","무수히 많다"],"answer":0,"explanation":"$y = 3$과 $y = -3$은 $y$값이 달라 평행한 가로선 → 교점 없음"}
  ]
