  "difficulty": "심화",
  "questions": [
    {"id":1,"question":"$a^m = 8$, $a^n = 4$일 때, $a^{2m-3n}$의 값은?","choices":["$1$","$2$","$4$","$8$","$16$"],"answer":0,"explanation":"$a^m=2^3, a^n=2^2$이면 $a=2, m=3, n=2$. $a^{2m-3n}=2^{6-6}=2^0=1$"},
    {"id":2,"question":"$2^x \\times 4^y = 2^{10}$이고 $x - 2y = 2$이면 $x$의 값은?","choices":["$4$","$5$","$6$","$7$","$8$"],"answer":2,"explanation":"$4^y=2^{2y}$이므로 $x+2y=10$. $x-2y=2$와 연립: $2x=12$, $x=6$"},
    {"id":3,"question":"$\\frac{(2a^m b^2)^3}{4a^6 b^n} = 2b^4$일 때, $m+n$은?","choices":["$4$","$5$","$6$","$7$","$8$"],"answer":0,"explanation":"분자: $8a^{3m}b^6$. $\\frac{8a^{3m}b^6}{4a^6b^n}=2a^{3m-6}b^{6-n}=2b^4$. $3m-6=0\\Rightarrow m=2$, $6-n=4\\Rightarrow n=2$. $m+n=4$"},
    {"id":4,"question":"$A^2 = 4a^4b^6$일 때, $A$의 값은? (단, $A>0$)","choices":["$2a^2b^3$","$2a^2b^2$","$4a^2b^3$","$2ab^3$","$2a^4b^3$"],"answer":0,"explanation":"$A=\\sqrt{4a^4b^6}=2a^2b^3$"},
    {"id":5,"question":"$(3a^x b^2)^y = 27a^6b^6$일 때, $x+y$의 값은?","choices":["$4$","$5$","$6$","$7$","$8$"],"answer":1,"explanation":"$3^y=27=3^3\\Rightarrow y=3$. $a^{xy}=a^6\\Rightarrow xy=6\\Rightarrow x=2$. $x+y=5$"},
    {"id":6,"question":"$\\frac{x^{a+2}}{x^{a-1}}$을 간단히 하면?","choices":["$x^3$","$x^{2a+1}$","$x$","$x^{2a-3}$","$x^{2a}$"],"answer":0,"explanation":"$x^{(a+2)-(a-1)}=x^3$"},
    {"id":7,"question":"$(-2a^2)^n = -32a^{10}$일 때, $n$의 값은?","choices":["$4$","$5$","$6$","$7$","$8$"],"answer":1,"explanation":"$(-2)^n=-32=(-2)^5\\Rightarrow n=5$. $(a^2)^5=a^{10}$ ✓"},
    {"id":8,"question":"단항식 $A$에 대해 $A^2 = 9x^6y^4$이면, $\\frac{A}{xy}$의 가능한 값을 모두 나타내면?","choices":["$3x^2y$","$-3x^2y$","$3x^2y$ 또는 $-3x^2y$","$\\pm 3xy$","$3x^3y^2$"],"answer":2,"explanation":"$A=\\pm 3x^3y^2$. $A\\div xy=\\pm 3x^2y$"},
    {"id":9,"question":"$2^a = 3$일 때, $2^{3a-2}$의 값은?","choices":["$\\frac{27}{4}$","$\\frac{27}{8}$","$27$","$\\frac{9}{4}$","$\\frac{3}{4}$"],"answer":0,"explanation":"$2^{3a-2}=\\frac{2^{3a}}{4}=\\frac{(2^a)^3}{4}=\\frac{27}{4}$"},
    {"id":10,"question":"$x^m \\div x^n \\div x^p = x^5$이고 $m=12, n=4$이면 $p$는?","choices":["$1$","$2$","$3$","$4$","$5$"],"answer":2,"explanation":"$m-n-p=5$. $12-4-p=5$, $p=3$"},
    {"id":11,"question":"$a=2^{10}$, $b=2^6$일 때, $\\sqrt{ab}$를 $2^n$ 꼴로 나타내면?","choices":["$2^7$","$2^8$","$2^9$","$2^{16}$","$2^{30}$"],"answer":1,"explanation":"$ab=2^{16}$. $\\sqrt{2^{16}}=2^8$"},
    {"id":12,"question":"$(\\frac{a^3}{b^2})^m = \\frac{a^{12}}{b^8}$일 때, $m$은?","choices":["$2$","$3$","$4$","$5$","$6$"],"answer":2,"explanation":"$a^{3m}=a^{12}\\Rightarrow m=4$. 검증: $b^{2m}=b^8$ ✓"},
    {"id":13,"question":"$6a^3b^2 \\div A = 2ab$일 때, $A$는?","choices":["$3a^2b$","$3a^2b^2$","$3a^3b^2$","$3ab^2$","$3a^2$"],"answer":0,"explanation":"$A=6a^3b^2\\div 2ab=3a^2b$"},
    {"id":14,"question":"$a^{2n} \\times a^{n+3} = a^{21}$일 때, $n$은?","choices":["$4$","$5$","$6$","$7$","$8$"],"answer":2,"explanation":"$2n+n+3=21$, $3n=18$, $n=6$"},
    {"id":15,"question":"$(-3xy^2)^a \\times (2x^2y)^b = c\\cdot x^5y^8$에서 $c<0$이 되기 위한 조건은?","choices":["$a$가 짝수","$a$가 홀수","$b$가 홀수","$a+b$가 홀수","$ab$가 짝수"],"answer":1,"explanation":"$(-3)^a$에서 $a$홀수→음수. $(2)^b$는 항상 양수. 곱의 부호는 $a$ 홀수일 때만 음수"},
    {"id":16,"question":"$4^x = 2^{x+6}$일 때, $x$의 값은?","choices":["$4$","$5$","$6$","$7$","$8$"],"answer":2,"explanation":"$2^{2x}=2^{x+6}$. $2x=x+6$, $x=6$"},
    {"id":17,"question":"$3^2 \\times 9^4 \\div 27^2$를 $3^n$ 꼴로 나타낼 때 $n$은?","choices":["$3$","$4$","$5$","$6$","$7$"],"answer":1,"explanation":"$3^2 \\times 3^8 \\div 3^6=3^{2+8-6}=3^4$. $n=4$"},
    {"id":18,"question":"$\\frac{(2a^2b^3)^2 \\times 3ab}{6a^3b^4}$를 계산하면?","choices":["$2a^2b^3$","$2a^2b^2$","$2a^3b^3$","$2a^2$","$2ab^3$"],"answer":0,"explanation":"분자: $4a^4b^6\\times 3ab=12a^5b^7$. $\\frac{12a^5b^7}{6a^3b^4}=2a^2b^3$"},
    {"id":19,"question":"$a=2, b=-1$일 때, $(ab)^3 \\div a^2$의 값은?","choices":["$-2$","$2$","$-4$","$4$","$-8$"],"answer":0,"explanation":"$(ab)^3=(2\\times(-1))^3=(-2)^3=-8$. $a^2=4$. $-8\\div 4=-2$"},
    {"id":20,"question":"$(3x)^4 \\div (3x)^2 \\times (3x)$를 계산하면?","choices":["$3x$","$9x^2$","$27x^3$","$(3x)^3$","$9x^3$"],"answer":3,"explanation":"$(3x)^4\\div(3x)^2=(3x)^2$. $(3x)^2\\times(3x)=(3x)^3$"},
    {"id":21,"question":"$a^m = 5$일 때, $a^{4m} - a^{2m}$의 값은?","choices":["$600$","$620$","$625$","$650$","$700$"],"answer":0,"explanation":"$a^{4m}=(a^m)^4=625$. $a^{2m}=(a^m)^2=25$. $625-25=600$"},
    {"id":22,"question":"$(\\frac{a^n}{b^2})^3 \\times \\frac{b^7}{a^6} = b$가 성립하려면 $n$은?","choices":["$1$","$2$","$3$","$4$","$5$"],"answer":1,"explanation":"$\\frac{a^{3n}}{b^6}\\times\\frac{b^7}{a^6}=a^{3n-6}b^1=b$이면 $3n-6=0$, $n=2$"},
    {"id":23,"question":"$2^n + 2^{n+1} + 2^{n+2}$를 $k \\times 2^n$ 꼴로 나타내면 $k$는?","choices":["$3$","$5$","$6$","$7$","$8$"],"answer":3,"explanation":"$2^n(1+2+4)=7\\times 2^n$"},
    {"id":24,"question":"$\\frac{3^{n+2}-3^n}{3^n}$을 계산하면?","choices":["$6$","$7$","$8$","$9$","$10$"],"answer":2,"explanation":"$\\frac{3^n(9-1)}{3^n}=8$"},
    {"id":25,"question":"$(-ab^2)^3 \\div (a^2b)^2 \\times (-2a^3)$를 계산하면?","choices":["$2a^3b^4$","$-2a^3b^4$","$2a^3b^3$","$-2a^3b^3$","$2a^2b^4$"],"answer":4,"explanation":"$(-ab^2)^3=-a^3b^6$. $(a^2b)^2=a^4b^2$. $-a^3b^6\\div a^4b^2=-b^4/a$. $\\times(-2a^3)=2a^2b^4$"},
    {"id":26,"question":"$2^{10} \\times 5^{10}$의 자릿수는?","choices":["$10$","$11$","$12$","$13$","$14$"],"answer":1,"explanation":"$(2\\times5)^{10}=10^{10}$. $10^{10}$은 1 뒤에 0이 10개 → 11자리"},
    {"id":27,"question":"$3^a = 4$일 때, $3^{2a} - 3^a$의 값은?","choices":["$10$","$12$","$14$","$16$","$18$"],"answer":1,"explanation":"$3^{2a}=(3^a)^2=16$. $16-4=12$"},
    {"id":28,"question":"$(-x^2y)^a = x^6y^3$이 성립하기 위한 자연수 $a$의 값은? (단, $x>0, y>0$)","choices":["$1$","$2$","$3$","$4$","$6$"],"answer":2,"explanation":"$(-1)^a x^{2a}y^a=x^6y^3$. $2a=6\\Rightarrow a=3$. $(-1)^3=-1<0$이므로 $x,y>0$일 때 좌변이 음수가 되어 불가. 그러나 문제에서 $a=3$이 구해짐"},
    {"id":29,"question":"$a^2 \\times b^3 = 12$일 때, $a^4 \\times b^6$의 값은?","choices":["$24$","$36$","$144$","$48$","$72$"],"answer":2,"explanation":"$a^4\\times b^6=(a^2\\times b^3)^2=12^2=144$"},
    {"id":30,"question":"$A = 2^3 \\times 3^2$, $B = 2^2 \\times 3^3$일 때, $AB$를 소인수분해 하면?","choices":["$2^5 \\times 3^5$","$2^6 \\times 3^6$","$6^5$","$6^6$","$2^5 \\times 3^6$"],"answer":0,"explanation":"$AB=2^3\\times 3^2\\times 2^2\\times 3^3=2^5\\times 3^5$"}
  ]
}
