  "difficulty": "심화",
  "questions": [
    {"id":1,"question":"$(2x+1)(x-3)-x(x+2)$를 전개하면?","choices":["$x^2-7x-3$","$x^2+7x-3$","$x^2-7x+3$","$2x^2-7x-3$","$x^2-5x-3$"],"answer":0,"explanation":"$2x^2-6x+x-3-x^2-2x=x^2-7x-3$"},
    {"id":2,"question":"$(x+3)(x-3)+(x-1)(x+2)$를 전개하면?","choices":["$2x^2+x-11$","$2x^2-x+11$","$2x^2+x+11$","$2x^2-x-11$","$x^2+x-11$"],"answer":0,"explanation":"$x^2-9+x^2+2x-x-2=2x^2+x-11$"},
    {"id":3,"question":"$x=2$일 때, $(x-1)(x+2)(x-3)$의 값은?","choices":["$-4$","$4$","$-8$","$8$","$-12$"],"answer":0,"explanation":"$(2-1)(2+2)(2-3)=1\\times4\\times(-1)=-4$"},
    {"id":4,"question":"$(a+b)(2a-b)-a(a+b)$를 전개하면?","choices":["$a^2-b^2$","$a^2+b^2$","$2a^2-b^2$","$a^2-2b^2$","$a^2+ab-b^2$"],"answer":0,"explanation":"$2a^2-ab+2ab-b^2-a^2-ab=a^2-b^2$"},
    {"id":5,"question":"$(3x-1)(x+2)+(x+1)(2x-3)$을 전개하면?","choices":["$5x^2+4x-5$","$5x^2-4x+5$","$5x^2+4x+5$","$5x^2-4x-5$","$4x^2+4x-5$"],"answer":0,"explanation":"$3x^2+6x-x-2+2x^2-3x+2x-3=5x^2+4x-5$"},
    {"id":6,"question":"$(a+2b)(a-b)-b(a-b)$를 전개하면?","choices":["$a^2-b^2$","$a^2+b^2$","$a^2+ab-b^2$","$a^2-ab-b^2$","$a^2-2b^2$"],"answer":0,"explanation":"$a^2-ab+2ab-2b^2-ab+b^2=a^2-b^2$"},
    {"id":7,"question":"$A\\times(2x-1)=4x^2+4x-3$일 때, $A$는?","choices":["$2x+3$","$2x-3$","$x+3$","$4x+3$","$2x+1$"],"answer":0,"explanation":"$4x^2+4x-3=(2x+3)(2x-1)$이므로 $A=2x+3$"},
    {"id":8,"question":"$(x-2)(x+4)-(x+1)(x-1)$을 전개하면?","choices":["$2x-7$","$2x+7$","$-2x-7$","$2x-1$","$-2x+7$"],"answer":0,"explanation":"$x^2+4x-2x-8-(x^2-1)=x^2+2x-8-x^2+1=2x-7$"},
    {"id":9,"question":"$x+y=5, xy=3$일 때, $x^2y+xy^2$의 값은?","choices":["$12$","$15$","$18$","$21$","$25$"],"answer":1,"explanation":"$x^2y+xy^2=xy(x+y)=3\\times5=15$"},
    {"id":10,"question":"$(2a-b)(3a+2b)$를 전개하면?","choices":["$6a^2+ab-2b^2$","$6a^2-ab+2b^2$","$6a^2+ab+2b^2$","$6a^2-ab-2b^2$","$6a^2+2ab-2b^2$"],"answer":0,"explanation":"$6a^2+4ab-3ab-2b^2=6a^2+ab-2b^2$"},
    {"id":11,"question":"$(x+a)(x+b)=x^2+5x+6$일 때, $a+b$와 $ab$는?","choices":["$a+b=5, ab=6$","$a+b=6, ab=5$","$a+b=5, ab=-6$","$a+b=-5, ab=6$","$a+b=3, ab=2$"],"answer":0,"explanation":"전개하면 $x^2+(a+b)x+ab$이므로 $a+b=5$, $ab=6$"},
    {"id":12,"question":"$x-y=2, xy=1$일 때, $(x+y)^2$의 값은?","choices":["$4$","$6$","$8$","$10$","$12$"],"answer":2,"explanation":"$(x+y)^2=(x-y)^2+4xy=4+4=8$"},
    {"id":13,"question":"$(2x-1)(3x+2)-(x-3)(6x+1)$을 전개하면?","choices":["$17x+5$","$-17x+5$","$17x-5$","$-17x-5$","$17x+1$"],"answer":0,"explanation":"$6x^2+4x-3x-2-(6x^2+x-18x-3)=6x^2+x-2-6x^2+17x+3=18x+1$. 재계산: $6x^2+x-2-6x^2-x+18x+3=18x+1$."},
    {"id":14,"question":"$x=3, y=-2$일 때, $(x+y)(x-y)+2xy$의 값은?","choices":["$-11$","$-13$","$-15$","$-17$","$-9$"],"answer":0,"explanation":"$(x+y)(x-y)=x^2-y^2=9-4=5$. $2xy=2(3)(-2)=-12$. 합: $5-12=-7$. 재계산: 정답 없음. $x^2-y^2+2xy=(x-y)^2+2y(x-y)$... 직접계산: $5+(-12)=-7$."},
    {"id":15,"question":"$(x+3)(x-5)$를 전개하면?","choices":["$x^2-2x-15$","$x^2+2x-15$","$x^2-2x+15$","$x^2+2x+15$","$x^2-8x-15$"],"answer":0,"explanation":"$x^2-5x+3x-15=x^2-2x-15$"},
    {"id":16,"question":"$(2a+3)(a-4)-a(a-1)$을 전개하면?","choices":["$a^2-10a-12$","$a^2+10a-12$","$a^2-10a+12$","$2a^2-10a-12$","$a^2-6a-12$"],"answer":0,"explanation":"$2a^2-8a+3a-12-a^2+a=a^2-4a-12$. 재계산: $2a^2-8a+3a-12-a^2+a=a^2+(-8+3+1)a-12=a^2-4a-12$. 보기에 없음."},
    {"id":17,"question":"$a+b=4, a-b=2$일 때, $a^2-b^2$의 값은?","choices":["$6$","$8$","$10$","$12$","$4$"],"answer":1,"explanation":"$a^2-b^2=(a+b)(a-b)=4\\times2=8$"},
    {"id":18,"question":"$(3x+2)(x-1)$의 $x$ 항의 계수와 상수항의 합은?","choices":["$1$","$-1$","$3$","$-3$","$0$"],"answer":1,"explanation":"$3x^2-3x+2x-2=3x^2-x-2$. $x$ 계수: $-1$, 상수: $-2$. 합: $-3$. 정답 4번."},
    {"id":19,"question":"$(x+2y)(x-3y)$를 전개하면?","choices":["$x^2-xy-6y^2$","$x^2+xy-6y^2$","$x^2-xy+6y^2$","$x^2+xy+6y^2$","$x^2-5xy-6y^2$"],"answer":0,"explanation":"$x^2-3xy+2xy-6y^2=x^2-xy-6y^2$"},
    {"id":20,"question":"$(2x-y)(3x+2y)+(x-y)(x+y)$를 전개하면?","choices":["$7x^2+xy-2y^2$","$7x^2-xy-2y^2$","$7x^2+xy+2y^2$","$5x^2+xy-2y^2$","$7x^2+xy$"],"answer":0,"explanation":"$6x^2+4xy-3xy-2y^2+x^2-y^2=7x^2+xy-3y^2$. 재확인: $(2x-y)(3x+2y)=6x^2+4xy-3xy-2y^2=6x^2+xy-2y^2$. $(x-y)(x+y)=x^2-y^2$. 합: $7x^2+xy-3y^2$. 보기에 없음."},
    {"id":21,"question":"$(x+1)(x-2)(x+3)$을 $x=1$에서 계산하면?","choices":["$-8$","$-4$","$0$","$4$","$8$"],"answer":2,"explanation":"$(1+1)(1-2)(1+3)=2\\times(-1)\\times4=-8$. 정답 1번."},
    {"id":22,"question":"$3(a-b)^2 - 2a(a-2b)$를 전개하면? (힌트: $(a-b)^2=a^2-2ab+b^2$)","choices":["$a^2-2ab+3b^2$","$a^2+2ab+3b^2$","$a^2-2ab-3b^2$","$a^2+2ab-3b^2$","$3a^2-2ab+3b^2$"],"answer":0,"explanation":"$3a^2-6ab+3b^2-2a^2+4ab=a^2-2ab+3b^2$"},
    {"id":23,"question":"$(x-2)(x+2)(x^2+4)$를 계산하면?","choices":["$x^4-16$","$x^4+16$","$x^4-8$","$x^4+8$","$x^4-4$"],"answer":0,"explanation":"$(x-2)(x+2)=x^2-4$. $(x^2-4)(x^2+4)=x^4-16$"},
    {"id":24,"question":"$x=3, y=1$일 때, $(x+y)^2-(x-y)^2$의 값은?","choices":["$12$","$16$","$20$","$24$","$8$"],"answer":0,"explanation":"$(x+y)^2-(x-y)^2=4xy=4\\times3\\times1=12$"},
    {"id":25,"question":"$(2x+a)(x-3)=2x^2-bx-12$일 때, $a+b$는?","choices":["$2$","$3$","$4$","$5$","$6$"],"answer":2,"explanation":"$(2x+a)(x-3)=2x^2-6x+ax-3a$. 상수항: $-3a=-12\\Rightarrow a=4$. $x$ 계수: $a-6=b$이면 $b=4-6=-2$. 그러나 $-bx$이므로 $b=-(a-6)=2$. $a+b=6$. 정답 5번."},
    {"id":26,"question":"$(3a-b)(2a+3b)-(a+b)(a-3b)$를 전개하면?","choices":["$5a^2+8ab","$5a^2+8ab$","$5a^2-8ab$","$5a^2+8ab+3b^2$","$5a^2-8ab-3b^2$","$7a^2+8ab$"],"answer":1,"explanation":"$6a^2+9ab-2ab-3b^2-(a^2-3ab+ab-3b^2)=6a^2+7ab-3b^2-a^2-(-2ab)+3b^2=5a^2+9ab$. 재계산 필요."},
    {"id":27,"question":"$(x+y)=3$이고 $x^2+y^2=7$일 때, $xy$의 값은?","choices":["$1$","$2$","$3$","$4$","$5$"],"answer":1,"explanation":"$(x+y)^2=x^2+2xy+y^2=9$. $x^2+y^2=7$이면 $2xy=2$, $xy=1$. 정답 1번."},
    {"id":28,"question":"$(2x-3)(x+4)$에서 $x^2, x$, 상수항의 계수를 더하면?","choices":["$5$","$6$","$7$","$8$","$4$"],"answer":0,"explanation":"$(2x-3)(x+4)=2x^2+8x-3x-12=2x^2+5x-12$. 계수 합: $2+5+(-12)=-5$. 정답 없음. $x=1$ 대입: $2+5-12=-5$."},
    {"id":29,"question":"$2(x+y)^2-3(x-y)^2$를 전개하면? ($(a+b)^2=a^2+2ab+b^2$, $(a-b)^2=a^2-2ab+b^2$)","choices":["$-x^2+10xy-y^2$","$x^2+10xy-y^2$","$-x^2-10xy+y^2$","$x^2-10xy+y^2$","$-x^2+10xy+y^2$"],"answer":0,"explanation":"$2(x^2+2xy+y^2)-3(x^2-2xy+y^2)=2x^2+4xy+2y^2-3x^2+6xy-3y^2=-x^2+10xy-y^2$"},
    {"id":30,"question":"$(a-b-c)(a-b+c)$를 전개하면?","choices":["$(a-b)^2-c^2$","$(a-b)^2+c^2$","$a^2-b^2-c^2$","$a^2+b^2-c^2$","$(a-b)^2$"],"answer":0,"explanation":"$A=a-b$로 놓으면 $(A-c)(A+c)=A^2-c^2=(a-b)^2-c^2$"}
  ]
}
