    {"id":1,"question":"$2x + y - 4 = 0$을 $y$에 대해 풀면?","choices":["$y = -2x + 4$","$y = 2x - 4$","$y = 2x + 4$","$y = -2x - 4$","$y = \\frac{1}{2}x + 2$"],"answer":0,"explanation":"$y = -2x + 4$"},
    {"id":2,"question":"$3x - y + 6 = 0$을 $y$에 대해 풀면?","choices":["$y = 3x + 6$","$y = -3x + 6$","$y = 3x - 6$","$y = -3x - 6$","$y = 6x + 3$"],"answer":0,"explanation":"$-y = -3x - 6$ → $y = 3x + 6$"},
    {"id":3,"question":"$x - 2y + 4 = 0$을 $y$에 대해 풀면?","choices":["$y = \\frac{1}{2}x + 2$","$y = -\\frac{1}{2}x + 2$","$y = 2x + 4$","$y = \\frac{1}{2}x - 2$","$y = -2x + 4$"],"answer":0,"explanation":"$-2y = -x - 4$ → $y = \\frac{1}{2}x + 2$"},
    {"id":4,"question":"$x = 3$의 그래프는?","choices":["$y$축에 평행한 직선","$x$축에 평행한 직선","$y = x + 3$","원점을 지나는 직선","기울기 $3$인 직선"],"answer":0,"explanation":"$x = k$ (상수)는 $y$축에 평행한 세로선"},
    {"id":5,"question":"$y = -2$의 그래프는?","choices":["$x$축에 평행한 직선","$y$축에 평행한 직선","기울기 $-2$인 직선","원점을 지나는 직선","$y = -2x$"],"answer":0,"explanation":"$y = k$ (상수)는 $x$축에 평행한 가로선"},
    {"id":6,"question":"$x = 0$의 그래프는?","choices":["$y$축","$x$축","원점을 지나고 기울기 $1$인 직선","기울기 $0$인 직선","$y = x$"],"answer":0,"explanation":"$x = 0$은 $y$축을 나타냄"},
    {"id":7,"question":"$y = 0$의 그래프는?","choices":["$x$축","$y$축","기울기 $0$인 직선이지만 $x$축 아님","원점만 통과","$y = x$"],"answer":0,"explanation":"$y = 0$은 $x$축을 나타냄"},
    {"id":8,"question":"$4x - 2y - 8 = 0$에서 $x$절편은?","choices":["$2$","$-2$","$4$","$-4$","$8$"],"answer":0,"explanation":"$y = 2x - 4$로 변환. $x$절편: $0 = 2x - 4$ → $x = 2$"},
    {"id":9,"question":"$4x - 2y - 8 = 0$에서 $y$절편은?","choices":["$-4$","$4$","$-2$","$2$","$-8$"],"answer":0,"explanation":"$y = 2x - 4$. $y$절편 $= -4$"},
    {"id":10,"question":"연립방정식 $\\begin{cases} y = x + 2 \\\\ y = -x + 4 \\end{cases}$의 해는?","choices":["$(1, 3)$","$(3, 1)$","$(2, 4)$","$(0, 2)$","$(-1, 1)$"],"answer":0,"explanation":"$x + 2 = -x + 4$ → $2x = 2$ → $x = 1$, $y = 3$"},
    {"id":11,"question":"연립방정식 $\\begin{cases} y = 2x - 1 \\\\ y = x + 1 \\end{cases}$의 해는?","choices":["$(2, 3)$","$(3, 2)$","$(1, 2)$","$(0, 1)$","$(-1, -3)$"],"answer":0,"explanation":"$2x - 1 = x + 1$ → $x = 2$, $y = 3$"},
    {"id":12,"question":"두 직선 $y = 3x - 1$과 $y = 3x + 5$의 교점은?","choices":["없다 (평행)","$(0, -1)$","$(0, 5)$","무수히 많다","$(1, 2)$"],"answer":0,"explanation":"기울기 같고 $y$절편 다름 → 평행 → 교점 없음"},
    {"id":13,"question":"두 직선 $y = -2x + 3$과 $y = -2x + 3$의 교점은?","choices":["무수히 많다 (일치)","$(0, 3)$","$(1, 1)$","없다","$(\\frac{3}{2}, 0)$"],"answer":0,"explanation":"두 식이 같으므로 일치 → 교점 무수히 많음"},
    {"id":14,"question":"$3x - y = 0$이 나타내는 직선의 기울기는?","choices":["$3$","$-3$","$0$","$\\frac{1}{3}$","$-\\frac{1}{3}$"],"answer":0,"explanation":"$y = 3x$ → 기울기 $3$"},
    {"id":15,"question":"$2x + 3y - 6 = 0$의 $y$절편은?","choices":["$2$","$-2$","$3$","$-3$","$6$"],"answer":0,"explanation":"$3y = -2x + 6$ → $y = -\\frac{2}{3}x + 2$ → $y$절편 $= 2$"},
    {"id":16,"question":"$2x + 3y - 6 = 0$의 $x$절편은?","choices":["$3$","$-3$","$2$","$-2$","$6$"],"answer":0,"explanation":"$y = 0$일 때: $2x = 6$ → $x = 3$"},
    {"id":17,"question":"$x = -2$는 몇 사분면을 지나는가?","choices":["2사분면과 3사분면","1사분면과 4사분면","모든 사분면","2사분면만","$y$축"],"answer":0,"explanation":"$x = -2$는 $y$축 왼쪽의 세로선 → $y > 0$이면 2사분면, $y < 0$이면 3사분면"},
    {"id":18,"question":"$y = 4$는 어느 사분면을 지나는가?","choices":["1사분면과 2사분면","3사분면과 4사분면","모든 사분면","1사분면만","$x$축 위"],"answer":0,"explanation":"$y = 4 > 0$인 가로선 → $x > 0$이면 1사분면, $x < 0$이면 2사분면"},
    {"id":19,"question":"연립방정식 $\\begin{cases} 2x + y = 5 \\\\ x - y = 1 \\end{cases}$의 해는?","choices":["$(2, 1)$","$(1, 2)$","$(3, -1)$","$(0, 5)$","$(3, 1)$"],"answer":0,"explanation":"더하면 $3x = 6$ → $x = 2$, $y = 5 - 4 = 1$"},
    {"id":20,"question":"$-x + 2y + 4 = 0$의 그래프의 기울기는?","choices":["$\\frac{1}{2}$","$-\\frac{1}{2}$","$2$","$-2$","$1$"],"answer":0,"explanation":"$2y = x - 4$ → $y = \\frac{1}{2}x - 2$ → 기울기 $\\frac{1}{2}$"},
    {"id":21,"question":"두 직선 $y = ax + 3$과 $y = 2x - 1$이 평행할 때 $a$는?","choices":["$2$","$-2$","$3$","$-3$","$1$"],"answer":0,"explanation":"평행 → 기울기 같음 → $a = 2$"},
    {"id":22,"question":"두 직선 $y = -x + k$와 $y = -x + 3$이 일치할 때 $k$는?","choices":["$3$","$-3$","$1$","$-1$","$0$"],"answer":0,"explanation":"일치 → $y$절편 같음 → $k = 3$"},
    {"id":23,"question":"$y = 2$와 $x = -3$의 교점은?","choices":["$(-3, 2)$","$(2, -3)$","$(0, 2)$","$(-3, 0)$","원점"],"answer":0,"explanation":"$x = -3$, $y = 2$이므로 교점 $(-3, 2)$"},
    {"id":24,"question":"$5x - 2y + 10 = 0$의 $y$절편은?","choices":["$5$","$-5$","$2$","$-2$","$10$"],"answer":0,"explanation":"$-2y = -5x - 10$ → $y = \\frac{5}{2}x + 5$ → $y$절편 $= 5$"},
    {"id":25,"question":"$5x - 2y + 10 = 0$의 $x$절편은?","choices":["$-2$","$2$","$-5$","$5$","$10$"],"answer":0,"explanation":"$y = 0$: $5x + 10 = 0$ → $x = -2$"},
    {"id":26,"question":"연립방정식의 두 그래프가 평행할 때 해는?","choices":["없다","하나","무수히 많다","두 개","네 개"],"answer":0,"explanation":"평행 → 교점 없음 → 해 없음"},
    {"id":27,"question":"연립방정식의 두 그래프가 일치할 때 해는?","choices":["무수히 많다","없다","하나","두 개","세 개"],"answer":0,"explanation":"일치 → 모든 점이 교점 → 해 무수히 많음"},
    {"id":28,"question":"$3x + y - 9 = 0$에서 $x = 2$일 때 $y$는?","choices":["$3$","$-3$","$15$","$-15$","$9$"],"answer":0,"explanation":"$3(2) + y - 9 = 0$ → $6 + y = 9$ → $y = 3$"},
    {"id":29,"question":"$ax + by = c$에서 $a = 1, b = -1, c = 3$이면 $x$절편은?","choices":["$3$","$-3$","$1$","$-1$","$0$"],"answer":0,"explanation":"$x - y = 3$. $y = 0$: $x = 3$"},
