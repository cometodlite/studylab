rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null) == 'admin';
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid
        && request.resource.data.get('role', null) == resource.data.get('role', null);
    }

    match /exam_sessions/{doc} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /exam_attempts/{doc} {
      allow read, write: if request.auth != null;
    }

    match /school_exam_sessions/{doc} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null) == 'admin');
    }

    match /school_exam_attempts/{doc} {
      allow read, write: if request.auth != null;
    }

    match /wrong_notes/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /point_logs/{doc} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null) == 'admin');
    }

    match /purchases/{doc} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /coupons/{doc} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /coupon_items/{doc} {
      allow read: if true;
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if request.auth != null;
    }

    match /roadway_progress/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /inquiries/{doc} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null) == 'admin');
    }
  }
}
