rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null) == 'admin';
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.get('role', null) == 'user';
      allow update: if isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.get('role', null) == resource.data.get('role', null);
    }

    match /exam_sessions/{doc} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isAdmin();
    }

    match /exam_attempts/{doc} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    match /school_exam_sessions/{doc} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isAdmin();
    }

    match /school_exam_attempts/{doc} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    match /wrong_notes/{doc} {
      allow create: if isOwner(request.resource.data.uid);
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow update: if isOwner(resource.data.uid)
        && request.resource.data.uid == resource.data.uid;
    }

    match /point_logs/{doc} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isAdmin();
    }

    match /purchases/{doc} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isAdmin();
    }

    match /coupons/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupon_items/{doc} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.get('isUsed', false) == false)
        || (signedIn() && resource.data.get('usedBy', null) == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (signedIn()
          && resource.data.get('isUsed', false) == false
          && request.resource.data.get('isUsed', false) == true
          && request.resource.data.get('usedBy', null) == request.auth.uid);
    }

    match /roadway_progress/{doc} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    match /inquiries/{doc} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
